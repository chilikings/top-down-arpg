MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4967377591894697519}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 716f36a4adb645b4f878c35326183d1f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  ShowEvents: 1
  ID:
    UseConstant: 1
    ConstantValue: 0
    Variable: {fileID: 0}
  Auto: 1
  InvokeOnEnable: 1
  Description: 'Check Stamina Stat Value.  Connected with Stat[Stamina].OnValueChanged

    -
    Disable Dodge if is less than 25.

    - Enable Dodge if is greater than 25. '
  ShowDescription: 1
  debug: 0
  value:
    UseConstant: 1
    ConstantValue: 0
    Variable: {fileID: 0}
  Raise:
    m_PersistentCalls:
      m_Calls: []
  compare:
  - active: 1
    name: 'Stamina Lower Than '
    description: 'Disable the Dodge Mode if the Stamina is lower than 25.

      Disable
      the 1st  comparer and Enable the second one.'
    comparer: 2
    Value:
      UseConstant: 1
      ConstantValue: 25
      Variable: {fileID: 0}
    Response:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 456536449787040972}
          m_TargetAssemblyTypeName: MalbersAnimations.Controller.MAnimal, MalbersAnimations
          m_MethodName: Mode_Disable
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 11400000, guid: 7888596ce3530b145bc15622fac8a6c4, type: 2}
            m_ObjectArgumentAssemblyTypeName: MalbersAnimations.ModeID, MalbersAnimations
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 4719403943373609471}
          m_TargetAssemblyTypeName: MalbersAnimations.FloatComparer, MalbersAnimations
          m_MethodName: Index_Enable_Only
          m_Mode: 3
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 1
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
    UpdateAfterCompare: 0
  - active: 1
    name: 'Stamina Greater Than '
    description: 'Enable the Dodge Mode if the Stamina is greater than 25.

      Disable
      the 2nd comparer and Enable the First one.'
    comparer: 1
    Value:
      UseConstant: 1
      ConstantValue: 25
      Variable: {fileID: 0}
    Response:
      m_PersistentCalls:
        m_Calls:
        - m_Target: {fileID: 456536449787040972}
          m_TargetAssemblyTypeName: MalbersAnimations.Controller.MAnimal, MalbersAnimations
          m_MethodName: Mode_Enable
          m_Mode: 2
          m_Arguments:
            m_ObjectArgument: {fileID: 11400000, guid: 7888596ce3530b145bc15622fac8a6c4, type: 2}
            m_ObjectArgumentAssemblyTypeName: MalbersAnimations.ModeID, MalbersAnimations
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
        - m_Target: {fileID: 4719403943373609471}
          m_TargetAssemblyTypeName: MalbersAnimations.FloatComparer, MalbersAnimations
          m_MethodName: Index_Enable_Only
          m_Mode: 3
          m_Arguments:
            m_ObjectArgument: {fileID: 0}
            m_ObjectArgumentAssemblyTypeName: UnityEngine.Object, UnityEngine
            m_IntArgument: 0
            m_FloatArgument: 0
            m_StringArgument: 
            m_BoolArgument: 0
          m_CallState: 2
    UpdateAfterCompare: 0
  OnValueChanged:
    m_PersistentCalls:
      m_Calls: []
